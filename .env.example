# ============================================================
# FinoraXpense — Environment Variables Template
# Copy this file as .env and fill in your real values.
# NEVER commit the .env file to GitHub!
# ============================================================

# Flask Core Configuration
SECRET_KEY=change_this_to_a_very_long_random_string_min_32_chars
FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Neon PostgreSQL Database
# Get from: https://neon.tech → Your Project → Connection String
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

# Anthropic Claude AI API Key
# Get from: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-your_api_key_here

# Admin Panel Registration Secret
# Anyone with this key can register as Admin
ADMIN_SECRET=choose_a_strong_admin_secret_key

# Google OAuth 2.0 Credentials
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret_here
